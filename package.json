{
  "name": "wiremock-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "better-sqlite3",
      "@prisma/engines"
    ]
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:frontend": "pnpm --filter @wiremock-hub/frontend dev",
    "dev:backend": "pnpm --filter @wiremock-hub/backend dev",
    "build": "pnpm -r build",
    "build:frontend": "pnpm --filter @wiremock-hub/frontend build",
    "build:backend": "pnpm --filter @wiremock-hub/backend build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,mjs,ts,vue,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,mjs,ts,vue,json,css,md}\"",
    "db:generate": "pnpm --filter @wiremock-hub/backend db:generate",
    "test:e2e": "pnpm --filter @wiremock-hub/e2e test",
    "test:e2e:ui": "pnpm --filter @wiremock-hub/e2e test:ui",
    "test:e2e:headed": "pnpm --filter @wiremock-hub/e2e test:headed",
    "test:e2e:keep-data": "pnpm --filter @wiremock-hub/e2e test:keep-data",
    "test:e2e:keep-data:headed": "pnpm --filter @wiremock-hub/e2e test:keep-data:headed"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@vue/eslint-config-typescript": "^14.1.3",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2"
  }
}
